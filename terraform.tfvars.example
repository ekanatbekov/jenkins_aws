aws_region          = "us-east-1"
project_name        = "jenkins-on-demand"
environment         = "dev"
owner               = "esen"
instance_type       = "t3.small"
allowed_cidr_blocks = ["YOUR_PUBLIC_IP/32"]

# Keep empty if you want SSM-only access
ssh_allowed_cidr_blocks = []

jenkins_admin_username = "admin"
